{
  "name": "inventory-monitor",
  "version": "0.3.0",
  "description": "Desktop inventory monitoring and material issue tracking",
  "author": "josephmqiu <39745128+josephmqiu@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/josephmqiu/OpenInventory",
  "repository": {
    "type": "git",
    "url": "https://github.com/josephmqiu/OpenInventory.git"
  },
  "bugs": {
    "url": "https://github.com/josephmqiu/OpenInventory/issues"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:native:electron && electron-vite dev",
    "dev:api": "npx tsx scripts/run-with-node-native-restore.ts \"npx tsx scripts/dev-api-server.ts\"",
    "dev:preview": "npx tsx scripts/run-with-node-native-restore.ts \"npx tsx scripts/dev-api-server.ts & npx vite --config vite.preview.config.ts\"",
    "build": "electron-vite build",
    "rebuild:native:node": "node -e \"try{require('fs').unlinkSync('node_modules/.electron-rebuild-hash')}catch{}\" && npm rebuild better-sqlite3",
    "rebuild:native:electron": "npx tsx scripts/rebuild-electron-native-deps.ts",
    "lint": "eslint src/",
    "preview": "vite preview",
    "test": "npx tsx scripts/run-with-node-native-restore.ts \"vitest run --config vitest.workspace.ts\"",
    "test:watch": "npx tsx scripts/run-with-node-native-restore.ts \"vitest --config vitest.workspace.ts\"",
    "test:backend": "npx tsx scripts/run-with-node-native-restore.ts \"vitest run --config vitest.config.node.ts\"",
    "test:backend:watch": "npx tsx scripts/run-with-node-native-restore.ts \"vitest --config vitest.config.node.ts\"",
    "test:coverage": "npx tsx scripts/run-with-node-native-restore.ts \"vitest run --config vitest.coverage.config.ts && npx tsx scripts/check-focused-coverage.ts\"",
    "test:e2e": "npx tsx scripts/run-e2e-lane.ts full --build",
    "test:e2e:run": "npx tsx scripts/run-e2e-lane.ts full",
    "test:e2e:smoke": "npx tsx scripts/run-e2e-lane.ts smoke --build",
    "test:e2e:smoke:run": "npx tsx scripts/run-e2e-lane.ts smoke",
    "test:e2e:parallel-safe": "npx tsx scripts/run-e2e-lane.ts parallel-safe --build",
    "test:e2e:parallel-safe:run": "npx tsx scripts/run-e2e-lane.ts parallel-safe",
    "test:e2e:report": "npx tsx scripts/report-e2e-results.ts",
    "test:e2e:cleanup": "npm run rebuild:native:electron",
    "verify": "npm run lint && npm run test",
    "verify:ci": "npm run verify",
    "verify:push": "npm run verify && npm run test:e2e",
    "verify:release": "npm run verify && npm run test:coverage && npm run test:e2e",
    "pack": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run rebuild:native:electron && electron-builder --dir",
    "dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run rebuild:native:electron && electron-builder",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/schema": "^0.75.5",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "effect": "^3.21.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "i18next": "^26.0.3",
    "i18next-icu": "^2.4.3",
    "intl-messageformat": "^11.2.0",
    "jsdom": "^29.0.1",
    "lucide-react": "^1.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.1.12",
    "vitest": "^4.1.5"
  }
}
