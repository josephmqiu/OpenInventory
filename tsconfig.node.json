{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./out",
    "target": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "electron.vite.config.ts",
    "src/shared/**/*.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "scripts/**/*.ts",
    "e2e/**/*.ts",
    "vitest.config.node.ts",
    "vitest.coverage.config.ts",
    "playwright.config.ts"
  ]
}
